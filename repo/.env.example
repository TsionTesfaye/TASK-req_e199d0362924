# Copy this file to .env and fill in the values before starting the stack.
# Never commit a real .env file — it is listed in .gitignore.

# Required: AES-256-GCM key for patient PII encryption (32+ bytes).
# Generate with: openssl rand -hex 32
# No default exists in production. The backend fails to start if this is unset or < 32 bytes.
ENCRYPTION_KEY=replace-this-with-a-real-64-hex-char-value-from-openssl

# Optional overrides — defaults match docker-compose.yml values.
# MYSQL_ROOT_PASSWORD=rootpw
# MYSQL_DATABASE=rescuehub
# MYSQL_USER=rescue
# MYSQL_PASSWORD=rescuepw
